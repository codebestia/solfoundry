{
  "name": "@solfoundry/bounty-registry",
  "version": "0.1.0",
  "description": "On-chain bounty registry program tests and SDK",
  "private": true,
  "scripts": {
    "build": "anchor build",
    "test": "anchor test",
    "test:unit": "npx ts-mocha -p ./tsconfig.json -t 120000 tests/**/*.ts",
    "test:bankrun": "npx ts-mocha -p ./tsconfig.json -t 60000 tests/bankrun/**/*.ts",
    "test:coverage": "c8 --reporter=text --reporter=lcov npx ts-mocha -p ./tsconfig.json -t 120000 tests/**/*.ts",
    "lint": "cargo clippy --manifest-path programs/bounty-registry/Cargo.toml -- -D warnings"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.91.0",
    "@solana/spl-token": "^0.4.6",
    "bn.js": "^5.2.1"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "c8": "^9.1.0",
    "chai": "^4.3.10",
    "mocha": "^10.3.0",
    "solana-bankrun": "^0.3.1",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.3.3"
  }
}
